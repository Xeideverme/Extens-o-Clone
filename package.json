{
  "name": "clone3d-snapshot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:extension": "pnpm --filter @clone3d/extension build",
    "build:worker": "pnpm --filter @clone3d/shared build && pnpm --filter @clone3d/worker build",
    "typecheck": "pnpm --filter @clone3d/shared build && pnpm --filter @clone3d/storage build && pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.33",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.18.0"
  }
}
